{
  "variables": {
    "apiKey": "bf69486b-4733-4470-a592-f1bfce7af580",
    "testUserId": "00000000-0000-0000-0000-000000000001",
    "testUserPassword": "password",
    "adminUserId": "00000000-0000-0000-0000-000000000002",
    "adminUserPassword": "password"
  },
  "apiKeys": [
    {
      "key": "#{apiKey}",
      "description": "MCP Server API Key"
    }
  ],
  "licenseId": "YOUR_LICENSE_KEY_HERE",
  "requests": [
    {
      "method": "PATCH",
      "url": "/api/tenant/#{FUSIONAUTH_TENANT_ID}",
      "body": {
        "tenant": {
          "issuer": "http://localhost:9011"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/#{testUserId}",
      "body": {
        "user": {
          "email": "test@example.com",
          "firstName": "Test",
          "lastName": "User",
          "password": "#{testUserPassword}",
          "username": "testuser"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{adminUserId}",
      "body": {
        "user": {
          "email": "admin@example.com",
          "firstName": "Admin",
          "lastName": "User",
          "password": "#{adminUserPassword}",
          "username": "admin"
        },
        "registration": {
          "applicationId": "#{FUSIONAUTH_APPLICATION_ID}",
          "roles": [
            "admin"
          ]
        }
      }
    }
  ]
}
